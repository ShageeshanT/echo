# Copy to .env and fill in. .env is git-ignored.

# --- LLM brain ---
GROQ_API_KEY=your_groq_api_key_here          # https://console.groq.com — free Llama 3.3 70b
GEMINI_API_KEY=your_gemini_api_key_here      # https://aistudio.google.com/app/apikey — free vision + tool calling

# --- TTS ---
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# --- Optional, used in later phases ---
# HF_TOKEN=                   # HuggingFace, only if using gated diarization models
# GOOGLE_OAUTH_CLIENT_JSON=   # path to client_secret.json for Gmail/Calendar (Phase 6)
